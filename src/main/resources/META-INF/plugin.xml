<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>org.marimo.pycharm</id>
    <name>marimo for PyCharm</name>
    <vendor>marimo</vendor>
    <description><![CDATA[
        <p>Open <b>marimo</b> notebooks (<code>.py</code>) inside PyCharm. PoC: renders the marimo web editor in an embedded JCEF browser tab.</p>
        <p>20% project — strict fail-fast PoC. See <code>.context/plan.md</code>.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.python</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <resource-bundle>messages.MarimoBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <fileEditorProvider implementation="com.github.kirangadhave.marimopycharm.editor.MarimoFileEditorProvider"/>
        <toolWindow id="marimo Variables" anchor="right" secondary="true"
                    factoryClass="com.github.kirangadhave.marimopycharm.vars.MarimoVariablesToolWindowFactory"/>
        <notificationGroup id="Marimo" displayType="BALLOON"/>
    </extensions>

    <actions>
        <group id="Marimo.Pair"
               class="com.github.kirangadhave.marimopycharm.pair.MarimoPairActionGroup"
               text="Pair with marimo"
               description="Start an AI harness paired on this marimo notebook, or copy its prompt"
               icon="AllIcons.Actions.Lightning"
               popup="true">
            <add-to-group group-id="EditorTabPopupMenu" anchor="last"/>
        </group>
    </actions>
</idea-plugin>
